{
  "$schema": "https://opencode.ai/config.json",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8000,
    "tail_turns": 5
  },
  "tool_output": {
    "max_lines": 100,
    "max_bytes": 4096
  },
  "plugin": [
    "opencode-token-optimizer",
    "@madtech/opencode-context-manager-plugin@latest"
  ]
}
